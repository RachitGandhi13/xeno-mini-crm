# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# Use the *pooled* connection string from Neon/Supabase dashboard for production.
# Append ?sslmode=require for managed cloud databases.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── AI Integration (wired in Phase 3) ─────────────────────────────────────
# Uses Claude Haiku (claude-haiku-4-5-20251001) via Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# ─── Channel Service (wired in Phase 2) ─────────────────────────────────────
# URL of the stub channel service
CHANNEL_SERVICE_URL=http://localhost:3002
# The URL this CRM exposes for async delivery receipts — channel service calls back here
CRM_RECEIPT_CALLBACK_URL=http://localhost:3001/api/receipts/callback
